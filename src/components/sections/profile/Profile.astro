---
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations } from '../../../i18n/ui';
import { socialLinks } from '../../../data/social';
import profilePhoto from '../../../assets/photo.webp';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="profile" class="profile-section">
	<div class="profile-wrapper">
		<div class="profile-info">
			<div class="header">
				<h1 class="name">David Garcia</h1>
				<h2 class="role">{t('profile.role')}</h2>
			</div>
			
			<p class="bio">
				{t('profile.bio')}
			</p>

			<div class="social-links">
				{socialLinks.map(social => (
					<a 
						href={social.url} 
						target={social.url.startsWith('mailto') ? '_self' : '_blank'} 
						rel={social.url.startsWith('mailto') ? '' : 'noopener noreferrer'} 
						aria-label={social.name} 
						class="social-icon" 
						set:html={social.icon} 
					/>
				))}
			</div>
		</div>
		
		<div class="profile-image-container">
			<Image src={profilePhoto} alt="David Garcia" class="profile-image" />
		</div>
	</div>
</section>

<style>
	.profile-section {
		display: flex;
		flex-direction: column;
	}

	.profile-wrapper {
		display: flex;
		flex-direction: column-reverse;
		gap: 2rem;
	}

	.profile-info {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.profile-image-container {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.profile-image {
		width: 160px;
		height: 160px;
		border-radius: 50%;
		object-fit: cover;
		border: 4px solid var(--border-light);
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
		transition: transform 0.3s ease, border-color 0.3s ease;
	}

	:global(.dark) .profile-image {
		border-color: var(--border-dark);
		box-shadow: 0 8px 30px rgba(255, 255, 255, 0.05);
	}

	.profile-image:hover {
		transform: scale(1.05);
	}

	.header {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.name {
		font-size: 2.25rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		color: var(--text-primary);
		line-height: 1.2;
	}

	.role {
		font-size: 1rem;
		font-weight: 500;
		color: var(--text-secondary);
	}

	.bio {
		font-size: 1rem;
		color: var(--text-secondary);
		max-width: 600px;
		line-height: 1.8;
		margin-top: 0.5rem;
	}

	.social-links {
		display: flex;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.social-icon {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-tertiary);
		padding: 0.5rem;
		margin-left: -0.5rem;
		border-radius: 0.5rem;
		font-size: 1.5rem;
		transition: all 0.2s ease;
	}

	.social-icon:hover {
		color: var(--text-primary);
		background-color: var(--bg-secondary);
		transform: translateY(-1px);
	}

	@media (min-width: 768px) {
		.profile-wrapper {
			flex-direction: row;
			justify-content: space-between;
			align-items: center;
			gap: 3rem;
		}

		.profile-info {
			flex: 1;
		}

		.profile-image-container {
			flex-shrink: 0;
		}

		.profile-image {
			width: 220px;
			height: 220px;
		}

		.name {
			font-size: 3rem;
		}
		.role {
			font-size: 1.125rem;
		}
		.bio {
			font-size: 1.125rem;
		}
	}
</style>

