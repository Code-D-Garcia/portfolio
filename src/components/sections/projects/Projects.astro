---
import { getLangFromUrl, useTranslations, type UIKeys } from '../../../i18n/ui';
import { projectsData } from '../../../data/projects';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="projects" class="projects-section">
	<h2 class="section-title">{t('projects.title')}</h2>
	
	<div class="projects-grid">
		{projectsData.map(project => (
			<article class="project-card">
				<div class="project-content">
					<div class="project-header">
						<h3 class="project-title">{t(`projects.${project.id}.title` as UIKeys)}</h3>
						<div class="project-links">
							<a href={project.repo} target="_blank" rel="noopener noreferrer" class="link">{t('projects.link.code')}</a>
							<a href={project.link} target="_blank" rel="noopener noreferrer" class="link">{t('projects.link.visit')}</a>
						</div>
					</div>
					<p class="project-description">{t(`projects.${project.id}.desc` as UIKeys)}</p>

				</div>
				
				{project.stack && project.stack.length > 0 && (
					<div class="project-stack-container">
						<div class="project-stack">
							{project.stack.map(tech => (
								<span class="stack-tag">{tech}</span>
							))}
						</div>
					</div>
				)}
			</article>
		))}
	</div>
</section>

<style>
	.projects-section {
		display: flex;
		flex-direction: column;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 640px) {
		.projects-grid {
			grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		}
	}

	.project-card {
		display: flex;
		flex-direction: column;
		background-color: var(--bg-primary);
		border: 1px solid var(--border-light);
		border-radius: 12px;
		overflow: hidden;
		transition: all 0.3s ease;
	}

	.project-card:hover {
		border-color: var(--border-dark);
		box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
		transform: translateY(-4px);
	}

	:global(.dark) .project-card:hover {
		box-shadow: 0 10px 40px -10px rgba(255, 255, 255, 0.03);
	}

	.project-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.5rem;
		flex-grow: 1;
	}

	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
	}

	.project-title {
		font-size: 1.125rem;
		font-weight: 600;
		color: var(--text-primary);
		line-height: 1.4;
	}

	.project-links {
		display: flex;
		gap: 0.75rem;
		flex-shrink: 0;
	}

	.link {
		font-size: 0.85rem;
		color: var(--text-tertiary);
		font-weight: 500;
		transition: color 0.2s ease;
	}

	.link:hover {
		color: var(--text-primary);
	}

	.project-description {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.project-stack-container {
		background-color: var(--bg-secondary);
		border-top: 1px solid var(--border-light);
		padding: 1rem 1.5rem;
		margin-top: auto;
	}

	.project-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.stack-tag {
		font-size: 0.75rem;
		font-weight: 500;
		color: var(--text-secondary);
		padding: 0.3rem 0.75rem;
		border-radius: 6px;
		background-color: var(--bg-tertiary);
		border: 1px solid var(--border-light);
		transition: all 0.2s ease;
		cursor: default;
	}

	.stack-tag:hover {
		color: var(--text-primary);
		background-color: var(--bg-primary);
		border-color: var(--border-dark);
		transform: translateY(-2px);
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
	}

	:global(.dark) .stack-tag:hover {
		box-shadow: 0 2px 8px rgba(255, 255, 255, 0.03);
	}
</style>
